import React,{useMemo,useState}from'react';import{createRoot}from'react-dom/client';import{TrendingUp,Wallet,Bell,Search,ShieldAlert,Plus,BarChart3}from'lucide-react';import{motion}from'framer-motion';import'./style.css';
const watchlist=[{ticker:'NVDA',name:'Nvidia',sector:'AI / Semis',price:142.2,day:1.8,rsi:67,trend:'Bullish',score:78},{ticker:'AMD',name:'AMD',sector:'Semis',price:164.5,day:-1.1,rsi:42,trend:'Neutral',score:71},{ticker:'MU',name:'Micron',sector:'Memory',price:61.8,day:-2.4,rsi:34,trend:'Watch',score:74},{ticker:'QCOM',name:'Qualcomm',sector:'Semis',price:186.1,day:.7,rsi:58,trend:'Bullish',score:69},{ticker:'AVGO',name:'Broadcom',sector:'AI / Semis',price:1294.4,day:2.2,rsi:72,trend:'Extended',score:73},{ticker:'PLTR',name:'Palantir',sector:'AI Software',price:23.7,day:3.4,rsi:76,trend:'Hot',score:62},{ticker:'TSM',name:'TSMC',sector:'Semis',price:154.3,day:.9,rsi:61,trend:'Bullish',score:76},{ticker:'ASML',name:'ASML',sector:'Semis Equipment',price:930.1,day:-.4,rsi:49,trend:'Neutral',score:75}];
const initialPortfolio=[{asset:'MU',type:'Stock',leverage:'x1',buy:60,qty:20,current:61.8,stop:57,target:69,date:'2026-05-20'},{asset:'Silver ETF',type:'Leveraged ETF',leverage:'x3',buy:75,qty:15,current:93.5,stop:88,target:96,date:'2026-05-18'}];
function signalFor(i){if(i.rsi>=72)return{label:'Take profit',tone:'red'};if(i.rsi<=35&&i.score>=70)return{label:'Buy zone',tone:'green'};if(i.score>=72&&i.rsi<68)return{label:'Watch buy',tone:'blue'};return{label:'Wait',tone:'gray'}}function pct(a,b){return((b-a)/a)*100}
function App(){const[tab,setTab]=useState('dashboard');const[positions,setPositions]=useState(initialPortfolio);const[query,setQuery]=useState('');const[form,setForm]=useState({asset:'',type:'Stock',leverage:'x1',buy:'',qty:'',current:'',stop:'',target:'',date:new Date().toISOString().slice(0,10)});const filtered=useMemo(()=>watchlist.filter(x=>`${x.ticker} ${x.name} ${x.sector}`.toLowerCase().includes(query.toLowerCase())),[query]);const alerts=useMemo(()=>{const market=watchlist.filter(x=>x.rsi<=35||x.rsi>=70).map(x=>({title:`${x.ticker}: RSI ${x.rsi>=70?'suracheté':'survendu'}`,detail:x.rsi>=70?'Zone possible de prise de bénéfice.':'Zone d’entrée possible si la tendance confirme.'}));const port=positions.map(p=>{const perf=pct(+p.buy,+p.current);if(+p.current>=+p.target)return{title:`${p.asset}: objectif atteint`,detail:'Prendre bénéfice ou remonter le stop.'};if(+p.current<=+p.stop)return{title:`${p.asset}: stop touché`,detail:'Alerte de protection du capital.'};if(perf>=10)return{title:`${p.asset}: +10%`,detail:'Envisager une vente partielle.'};return null}).filter(Boolean);return[...market,...port]},[positions]);function addPos(){if(!form.asset||!form.buy||!form.qty)return;setPositions([{...form,buy:+form.buy,qty:+form.qty,current:+(form.current||form.buy),stop:+(form.stop||form.buy*.92),target:+(form.target||form.buy*1.12)},...positions]);setForm({...form,asset:'',buy:'',qty:'',current:'',stop:'',target:''})}return <div className="app"><div className="phone"><header><div><p>AI Trading Cockpit</p><h1>{tab==='dashboard'?'Market Scanner':tab==='portfolio'?'Portfolio':'Alerts'}</h1></div><div className="logo"><BarChart3 size={22}/></div></header>{tab==='dashboard'&&<main><div className="card"><div className="search"><Search size={16}/><input value={query} onChange={e=>setQuery(e.target.value)} placeholder="Search ticker, sector..."/></div></div><div className="card summary"><small>AI SUMMARY</small><p>Focus semi-conducteurs. MU approche une zone d’achat potentielle. AVGO et PLTR semblent tendus : discipline sur les prises de bénéfices.</p></div>{filtered.map((item,i)=>{const s=signalFor(item);return <motion.div key={item.ticker} initial={{opacity:0,y:8}} animate={{opacity:1,y:0}} transition={{delay:i*.03}} className="card"><div className="row"><div><h2>{item.ticker} <span className={'pill '+s.tone}>{s.label}</span></h2><p className="muted">{item.name} · {item.sector}</p></div><div className="right"><b>${item.price}</b><span className={item.day>=0?'up':'down'}>{item.day>=0?'+':''}{item.day}%</span></div></div><div className="metrics"><Metric l="RSI" v={item.rsi}/><Metric l="Trend" v={item.trend}/><Metric l="Score" v={`${item.score}/100`}/></div></motion.div>})}</main>}{tab==='portfolio'&&<main><div className="card"><h3>Ajouter une position</h3><div className="grid"><input placeholder="Actif ex: AMD" value={form.asset} onChange={e=>setForm({...form,asset:e.target.value})}/><select value={form.type} onChange={e=>setForm({...form,type:e.target.value})}><option>Stock</option><option>ETF</option><option>Leveraged ETF</option><option>Mini Future</option><option>Call Option</option><option>Put Option</option></select><input placeholder="Levier x1/x3" value={form.leverage} onChange={e=>setForm({...form,leverage:e.target.value})}/><input placeholder="Prix achat" value={form.buy} onChange={e=>setForm({...form,buy:e.target.value})}/><input placeholder="Quantité" value={form.qty} onChange={e=>setForm({...form,qty:e.target.value})}/><input placeholder="Prix actuel" value={form.current} onChange={e=>setForm({...form,current:e.target.value})}/><input placeholder="Stop" value={form.stop} onChange={e=>setForm({...form,stop:e.target.value})}/><input placeholder="Objectif" value={form.target} onChange={e=>setForm({...form,target:e.target.value})}/></div><button onClick={addPos}><Plus size={16}/> Ajouter</button></div>{positions.map(p=>{const perf=pct(+p.buy,+p.current),pnl=(+p.current-+p.buy)*+p.qty;return <div className="card" key={p.asset}><div className="row"><div><h2>{p.asset}</h2><p className="muted">{p.type} · {p.leverage} · {p.date}</p></div><div className="right"><b className={perf>=0?'up':'down'}>{perf>=0?'+':''}{perf.toFixed(2)}%</b><span>${((+p.current)*(+p.qty)).toFixed(0)}</span></div></div><div className="metrics"><Metric l="Buy" v={`$${p.buy}`}/><Metric l="Now" v={`$${p.current}`}/><Metric l="P/L" v={`${pnl>=0?'+':''}$${pnl.toFixed(0)}`}/></div><p className="muted small">Stop: ${p.stop} · Target: ${p.target}</p></div>})}</main>}{tab==='alerts'&&<main>{alerts.map((a,i)=><div className="card alert" key={i}><ShieldAlert size={22}/><div><h3>{a.title}</h3><p>{a.detail}</p></div></div>)}</main>}<nav><Nav a={tab==='dashboard'} onClick={()=>setTab('dashboard')} i={<TrendingUp/>} l="Scanner"/><Nav a={tab==='portfolio'} onClick={()=>setTab('portfolio')} i={<Wallet/>} l="Portfolio"/><Nav a={tab==='alerts'} onClick={()=>setTab('alerts')} i={<Bell/>} l="Alerts"/></nav></div></div>}
function Metric({l,v}){return <div className="metric"><small>{l}</small><b>{v}</b></div>}function Nav({a,onClick,i,l}){return <button onClick={onClick} className={a?'active':''}>{React.cloneElement(i,{size:18})}<span>{l}</span></button>}
createRoot(document.getElementById('root')).render(<App/>);
